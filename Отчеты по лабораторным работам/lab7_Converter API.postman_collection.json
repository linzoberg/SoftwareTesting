                  "pm.test(\"Результат округлён до 2 знаков\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    var resultStr = jsonData.result.toString();\r",
                  "    var parts = resultStr.split(\".\");\r",
                  "    if (parts.length === 2) {\r",
                  "        pm.expect(parts[1].length).to.be.at.most(2);\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Результат совпадает с amount * rate\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    var expected = Math.round(jsonData.amount * jsonData.rate * 100) / 100;\r",
                  "    pm.expect(jsonData.result).to.eql(expected);\r",
                  "});"
