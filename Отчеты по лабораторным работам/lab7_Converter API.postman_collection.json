          "name": "Запрос 02. Получение курса USD → EUR",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// ФП-2: Получение курса обмена (пара USD/EUR)\r",
                  "\r",
                  "pm.test(\"Статус-код равен 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Ответ в формате JSON\", function () {\r",
                  "    pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Поле success равно true\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.success).to.eql(true);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Rate является числом в диапазоне 0.5 - 1.5\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.rate).to.be.a(\"number\");\r",
                  "    pm.expect(jsonData.rate).to.be.above(0.5);\r",
                  "    pm.expect(jsonData.rate).to.be.below(1.5);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Коды валют соответствуют запросу\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.from).to.eql(\"USD\");\r",
                  "    pm.expect(jsonData.to).to.eql(\"EUR\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
