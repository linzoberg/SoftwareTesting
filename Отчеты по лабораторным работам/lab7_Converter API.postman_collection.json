        {
          "name": "Запрос 04. Конвертация 100 USD → EUR",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// ФП-3: Конвертация суммы (целое число, POST-запрос)\r",
                  "\r",
                  "pm.test(\"Статус-код равен 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Ответ содержит все обязательные поля\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property(\"success\");\r",
                  "    pm.expect(jsonData).to.have.property(\"from\");\r",
                  "    pm.expect(jsonData).to.have.property(\"to\");\r",
                  "    pm.expect(jsonData).to.have.property(\"amount\");\r",
                  "    pm.expect(jsonData).to.have.property(\"rate\");\r",
                  "    pm.expect(jsonData).to.have.property(\"result\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Результат является положительным числом\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.result).to.be.a(\"number\");\r",
                  "    pm.expect(jsonData.result).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Результат равен amount * rate\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    var expected = Math.round(jsonData.amount * jsonData.rate * 100) / 100;\r",
                  "    pm.expect(jsonData.result).to.eql(expected);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
